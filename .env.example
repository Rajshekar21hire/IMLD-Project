# Copy this file to .env and fill in your values before running docker compose.
# Only the variables you want to override are needed — all have sensible defaults.

# ── Security ────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production

# ── AI Chat Provider ─────────────────────────────────────────────────────────
# Options: ollama (default, free & local), gemini, openai
CHAT_PROVIDER=ollama

# Ollama — used when CHAT_PROVIDER=ollama
# The docker-compose Ollama service is pre-configured; you just need to pull a model:
#   docker compose exec ollama ollama pull llama3.2:3b
OLLAMA_MODEL=llama3.2:3b

# Google Gemini — used when CHAT_PROVIDER=gemini
# GEMINI_API_KEY=your-gemini-api-key-here
# GOOGLE_API_KEY=your-gemini-api-key-here
# GEMINI_MODEL=gemini-2.5-flash

# OpenAI — used when CHAT_PROVIDER=openai
# OPENAI_API_KEY=your-openai-api-key-here
