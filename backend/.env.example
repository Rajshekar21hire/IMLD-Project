FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your-secret-key-here
DATABASE_URL=sqlite:///air_quality_portal.db
OPENAI_API_KEY=your-openai-api-key-here
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5000

# Chat providers
# Default is Ollama so you can run everything locally for free.
CHAT_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2:3b
# Optional: use a different model for story generation than chat. Defaults to OLLAMA_MODEL if unset.
# OLLAMA_STORY_MODEL=llama3.2:3b
GEMINI_API_KEY=your-gemini-api-key-here
GOOGLE_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash
